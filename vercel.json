{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "installCommand": "cd astro-site && npm ci",
  "buildCommand": "cd astro-site && npm run build",
  "outputDirectory": "astro-site/dist",
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/city-service-base/",
      "destination": "/services/gutter-repair-tampa-fl/",
      "permanent": true
    },
    {
      "source": "/services/snow-ice-solutions-heat-tape-tampa-fl/",
      "destination": "/services/custom-gutters-tampa-fl/",
      "permanent": true
    },
    {
      "source": "/the-dangers-of-frozen-gutters/",
      "destination": "/what-are-seamless-gutters-and-why-florida-homes-need-them/",
      "permanent": true
    },
    {
      "source": "/heavy-rain-gutter-problems-tampa-fl/",
      "destination": "/what-are-seamless-gutters-and-why-florida-homes-need-them/",
      "permanent": true
    },
    {
      "source": "/gutter-repair-cost-in-denver-co/",
      "destination": "/seamless-gutters-the-homeowners-complete-guide/",
      "permanent": true
    },
    {
      "source": "/how-to-prevent-premature-gutter-failure/",
      "destination": "/soffit-fascia-protecting-your-roofs-hidden-edges/",
      "permanent": true
    },
    {
      "source": "/spend-now-save-big-why-gutter-leaf-protection-is-worth-it/",
      "destination": "/super-gutters-upgrade-from-5-to-7-inch-for-maximum-flow/",
      "permanent": true
    },
    {
      "source": "/gutter-cleaning-maintenance-101/",
      "destination": "/diy-vs-professional-gutter-installation-why-hire-an-expert/",
      "permanent": true
    },
    {
      "source": "/products-services/:slug/",
      "destination": "/services/:slug/",
      "permanent": true
    },
    {
      "source": "/:path((?!api/)(?!.*\\.).*[^/])",
      "destination": "/:path/",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/seamless-gutters/", "destination": "/services/seamless-gutters-tampa-fl/" },
    { "source": "/soffit-and-fascias/", "destination": "/services/soffit-fascia-repair-tampa-fl/" },
    { "source": "/super-gutters/", "destination": "/services/super-gutters-tampa-fl/" },
    { "source": "/screen-rooms-and-lanais/", "destination": "/services/screen-rooms-lanais-tampa-fl/" },
    { "source": "/underground-drainage/", "destination": "/services/underground-drainage-tampa-fl/" },
    { "source": "/siding/", "destination": "/services/siding-tampa-fl/" },
    { "source": "/siding-services-in-central-florida/", "destination": "/services/siding-tampa-fl/" },
    { "source": "/gutters-deerfield-beach-fl/", "destination": "/locations/gutters-deerfield-beach-fl/" },
    { "source": "/gutters-boca-raton-fl/", "destination": "/locations/gutters-boca-raton-fl/" },
    { "source": "/gutters-fort-lauderdale-fl/", "destination": "/locations/gutters-fort-lauderdale-fl/" },
    { "source": "/gutters-pompano-beach-fl/", "destination": "/locations/gutters-pompano-beach-fl/" },
    { "source": "/gutters-delray-beach-fl/", "destination": "/locations/gutters-delray-beach-fl/" },
    { "source": "/gutters-boynton-beach-fl/", "destination": "/locations/gutters-boynton-beach-fl/" },
    { "source": "/gutters-coral-springs-fl/", "destination": "/locations/gutters-coral-springs-fl/" },
    { "source": "/gutters-west-palm-beach-fl/", "destination": "/locations/gutters-west-palm-beach-fl/" },
    { "source": "/gutters-hollywood-fl/", "destination": "/locations/gutters-hollywood-fl/" },
    { "source": "/gutters-palm-beach-gardens-fl/", "destination": "/locations/gutters-palm-beach-gardens-fl/" }
  ],
  "functions": {
    "api/lead.js": {
      "maxDuration": 30
    }
  }
}
