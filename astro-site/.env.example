# Required: same Sanity project as sanity-studio (create at https://www.sanity.io/manage)
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# Optional: Editor token to run `npm run theme:aagf` or `npm run content:aagf` / `content:aagf:home` (patch Sanity)
# SANITY_API_WRITE_TOKEN=

# Production canonical URL — trailing slash optional (code strips it). Example:
# PUBLIC_SITE_URL=https://aaguttersflorida.com
PUBLIC_SITE_URL=

# reCAPTCHA v3 site key (public). Vercel + local should match your reCAPTCHA domain allowlist.
PUBLIC_RECAPTCHA_SITE_KEY=

# reCAPTCHA v3 secret (server only — Vercel env for /api/lead).
RECAPTCHA_SECRET_KEY=

# Mapbox token (public read token for address autofill on lead forms).
# PUBLIC_MAPBOX_TOKEN=

# Optional: minimum score 0.0–1.0 (default 0.5).
# RECAPTCHA_MIN_SCORE=0.5
