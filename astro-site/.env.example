# Required: same Sanity project as sanity-studio (create at https://www.sanity.io/manage)
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# Optional: Editor token to run `npm run theme:aagf` (applies logo-aligned theme colors to Site settings)
# SANITY_API_WRITE_TOKEN=

# Production canonical URL (https://www.your-domain.com) — used for sitemap, JSON-LD, and Astro `site`
PUBLIC_SITE_URL=

# Optional: reCAPTCHA v3 — public site key (BaseLayout falls back to production key if unset)
PUBLIC_RECAPTCHA_SITE_KEY=

# reCAPTCHA v3 secret (required on Vercel for /api/lead). From Google admin console.
RECAPTCHA_SECRET_KEY=

# Optional: minimum score 0.0–1.0 (default 0.5).
# RECAPTCHA_MIN_SCORE=0.5
