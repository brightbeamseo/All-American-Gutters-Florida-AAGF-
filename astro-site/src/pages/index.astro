---
import BaseLayout from '../layouts/BaseLayout.astro'
import UniquePointIcon from '../components/UniquePointIcon.astro'
import FooterSocialIcon from '../components/FooterSocialIcon.astro'
import FooterContactInfo from '../components/FooterContactInfo.astro'
import FooterHoursRow from '../components/FooterHoursRow.astro'
import { externalLinkAttrs } from '../lib/external-link.js'
import { googleBusinessProfileUrl, isContactFooterColumnHeading } from '../lib/footer-contact-heading.js'
import { getSiteSettings, getHomePage, mergeHeaderFromSettings } from '../lib/site-settings.js'
import {
  asStr,
  asStrArray,
  applyTemplate,
  escapeHtml,
  mediaUrl,
  statLookup,
} from '../lib/sanity-strings.js'
import { assertSanityHomepage } from '../lib/assert-sanity-homepage.js'
import { sanitizeCmsHtml } from '../lib/sanitize-cms-html.js'
import { southFloridaCopy, isHomeGuttersServiceItem } from '../lib/south-florida-home-copy.js'

const [settings, homePage] = await Promise.all([getSiteSettings(), getHomePage()])

assertSanityHomepage(settings, homePage)

const business = settings.business
const meta = settings.meta
const statsValues = settings.statsValues
const mapEmbedUrl = asStr(settings.mapEmbedUrl)

const companyName = asStr(business?.companyName)
const phoneDisplay = asStr(business?.phoneDisplay)
const tel = asStr(business?.phoneTel)
const email = asStr(business?.email)
const address = asStr(business?.addressShort)
const sfq = (v) => southFloridaCopy(v, address)
const addressHref = googleBusinessProfileUrl(settings)
const descriptionShort = asStr(business?.descriptionShort)
const copyrightHref = asStr(business?.copyrightSiteUrl)
const logoBlack = asStr(business?.logoHorizontalBlack)
const logoWhite = asStr(business?.logoHorizontalWhite)

const pageTitle = asStr(meta?.title)
const pageDescription = asStr(meta?.description)

const hp = homePage
const header = mergeHeaderFromSettings(settings, hp.header)
const offerBar = header?.offerBar
const navItems = header?.navItems
const hero = hp.hero
const brandsMarquee = hp.brandsMarquee
const projects = hp.projects
const whyChoose = hp.whyChoose
const whyStamp = whyChoose?.stamp
const whyCtas = whyChoose?.ctas
const services = hp.services
const servicesItemsFiltered = (Array.isArray(services?.items) ? services.items : [])
  .filter(isHomeGuttersServiceItem)
  .map((svc, i) => ({
    ...svc,
    number: String(i + 1).padStart(2, '0'),
  }))
const servicesHeadlineDisplay = 'Gutter services'
const about = hp.about
const aboutVideo = about?.video
const uniquePoints = hp.uniquePoints
const statsBar = hp.statsBar
const contactBanner = hp.contactBanner
const reviews = settings?.reviews ?? hp.reviews
const reviewsSummary = reviews?.summary
const reviewValues = reviews?.reviewValues
const serviceArea = hp.serviceArea
const team = hp.team
const faq = hp.faq
const footerEstimate = settings?.footerEstimate ?? hp.footerEstimate
const footerEstimateFields = footerEstimate?.formFields
const footerBrand = settings?.footerBrand ?? hp.footerBrand
const footerColumns = settings?.footerColumns ?? hp.footerColumns
const footerSupport = settings?.footerSupport ?? hp.footerSupport
const formsCfg = settings?.forms ?? {}

const reviewRating = statLookup(reviewValues, reviewsSummary?.ratingValueKey)
const reviewCount = statLookup(reviewValues, reviewsSummary?.reviewCountKey)
const reviewCountDisplay = `${asStr(reviewsSummary?.reviewCountPrefix)}${reviewCount}${asStr(reviewsSummary?.reviewCountSuffix)}`
const reviewsCtaHref = asStr(reviewsSummary?.ctaHref) || '/reviews/'

const callLabelNav = sfq(
  applyTemplate(asStr(header?.callCtaTemplate), {
    phoneDisplay,
  }),
)
const callLabelHero = sfq(
  applyTemplate(asStr(hero?.callCtaTemplate), {
    phoneDisplay,
  }),
)
const logoAriaLabel = sfq(
  applyTemplate(asStr(header?.logoAriaLabelTemplate), {
    companyName,
  }),
)

const telLink = `tel:${tel}`

const homesCountDisplay = sfq(
  applyTemplate(asStr(whyStamp?.homesCountTemplate), {
    count: statLookup(statsValues, whyStamp?.homesCountKey),
  }),
)

const whyCallLabel = sfq(
  applyTemplate(asStr(whyCtas?.callTemplate), {
    phoneDisplay,
  }),
)
const aboutCallLabel = sfq(
  applyTemplate(asStr(about?.ctas?.callTemplate), {
    phoneDisplay,
  }),
)

const mapIframeTitle = sfq(
  applyTemplate(asStr(serviceArea?.mapIframeTitleTemplate), {
    companyName,
  }),
)

const layoutBg = hp.layoutBackgrounds
const heroBgSrc = asStr(layoutBg?.hero?.imageSrc)
const servicesBgSrc = asStr(layoutBg?.services?.imageSrc)
const uniquePointsBgSrc = asStr(layoutBg?.uniquePoints?.imageSrc)

const heroBgStyle = `background-image: linear-gradient(135deg, rgba(56, 69, 85, 0.88) 0%, rgba(56, 69, 85, 0.84) 50%, rgba(56, 69, 85, 0.88) 100%), url("${mediaUrl(heroBgSrc)}"); background-size: cover; background-position: center; background-repeat: no-repeat;`

const servicesBgStyle = `background-color: #143980; background-image: linear-gradient(135deg, rgba(20, 57, 128, 0.94) 0%, rgba(26, 74, 158, 0.94) 100%), url("${mediaUrl(servicesBgSrc)}"); background-size: cover; background-position: center; background-repeat: no-repeat;`

const uniquePointsBgStyle = `background: var(--color-surface); background-image: url("${mediaUrl(uniquePointsBgSrc)}"); background-size: cover; background-position: center;`

const typedPhrases = asStrArray(hero?.typedPhrases).map((p) => sfq(p))

const aboutStillSrc = asStr(aboutVideo?.posterSrc) || asStr(whyChoose?.imageSrc) || ''

const copyrightTemplate = asStr(footerSupport?.copyrightTemplate)
const copyrightInnerHtml = sanitizeCmsHtml(
  copyrightTemplate
    .replace(/\{\{\s*year\s*\}\}/gi, '<span id="year"></span>')
    .replace(/\{\{\s*companyName\s*\}\}/gi, escapeHtml(companyName))
)

const universalFormFields = footerEstimateFields
const universalFormAction = asStr(formsCfg?.submitPath) || asStr(footerEstimate?.formAction)
const universalFormMethod = asStr(footerEstimate?.formMethod)
const universalFormHeading = asStr(footerEstimate?.headline)
const universalFormIntro = asStr(footerEstimate?.intro)
const universalFormHeadingDisplay = sfq(universalFormHeading)
const universalFormIntroDisplay = sfq(universalFormIntro)
const universalSubmitLabel = asStr(universalFormFields?.submitButton)
const universalFormKicker = asStr(formsCfg?.formKicker) || 'Free Estimate'
const universalFormAriaLabel = asStr(formsCfg?.formAriaLabel) || 'Lead form'
const universalRequiredIndicator = asStr(formsCfg?.requiredIndicator) || '*'

const normalizeLocationPageHref = (href) => {
  const value = asStr(href).trim()
  if (!value) return ''
  const legacyMap = {
    '/tampa-florida/': '/locations/tampa-florida/',
    '/brandon-florida/': '/locations/brandon-florida/',
    '/gutters-clearwater-fl/': '/locations/gutters-clearwater-fl/',
    '/gutters-saint-petersburg-fl/': '/locations/gutters-saint-petersburg-fl/',
    '/gutters-largo-fl/': '/locations/gutters-largo-fl/',
    '/gutters-plant-city-fl/': '/locations/gutters-plant-city-fl/',
    '/gutters-seffner-fl/': '/locations/gutters-seffner-fl/',
    '/apollo-beach-fl/': '/locations/apollo-beach-fl/',
    '/gutters-riverview-florida/': '/locations/gutters-riverview-florida/',
  }
  return legacyMap[value] || value
}

const normalizeServiceCardHref = (href) => {
  const value = asStr(href).trim()
  if (!value) return ''
  const legacyMap = {
    '/seamless-gutters/': '/seamless-gutters-tampa-fl/',
    '/soffit-and-fascias/': '/soffit-fascia-repair-tampa-fl/',
    '/super-gutters/': '/super-gutters-tampa-fl/',
    '/screen-rooms-and-lanais/': '/screen-rooms-lanais-tampa-fl/',
    '/underground-drainage/': '/underground-drainage-tampa-fl/',
    '/siding/': '/siding-tampa-fl/',
  }
  return legacyMap[value] || value
}

const serviceHref = (svc) => {
  const explicit = normalizeServiceCardHref(svc?.href)
  if (explicit) return explicit
  const title = asStr(svc?.title).toLowerCase().trim()
  if (!title) return '/seamless-gutters-tampa-fl/'
  const knownSlugs = {
    'seamless gutters': 'seamless-gutters-tampa-fl',
    'soffit & fascia': 'soffit-fascia-repair-tampa-fl',
    'soffit and fascia': 'soffit-fascia-repair-tampa-fl',
    'super gutters': 'super-gutters-tampa-fl',
    'screen rooms & lanais': 'screen-rooms-lanais-tampa-fl',
    'screen rooms and lanais': 'screen-rooms-lanais-tampa-fl',
    'underground drainage': 'underground-drainage-tampa-fl',
    siding: 'siding-tampa-fl',
  }
  if (knownSlugs[title]) return `/${knownSlugs[title]}/`
  const slug = title
    .replace(/&/g, ' and ')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '')
  return `/${slug}/`
}
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  theme={settings.theme}
  forms={{ submitPath: asStr(settings.forms?.submitPath) }}
  homeRevealAnimations
  preloadImageHref={mediaUrl(heroBgSrc)}
>
  <header class="header">
    <div class="offer-bar">
      <div class="offer-bar-inner">
        <p class="offer-message">
          {sfq(asStr(offerBar?.textBeforeDiscount))}
          <strong>{sfq(asStr(offerBar?.discountLabel))}</strong>
          {sfq(asStr(offerBar?.textAfterDiscount))}
          <a
            href={asStr(offerBar?.ctaHref)}
            class="offer-link"
            {...externalLinkAttrs(asStr(offerBar?.ctaHref))}
          >
            <strong>{sfq(asStr(offerBar?.ctaText))}</strong>
          </a>
        </p>
      </div>
    </div>

    <div class="header-nav">
      <div class="header-inner">
        <a href="/" class="logo" aria-label={logoAriaLabel}>
          <img src={mediaUrl(logoBlack)} alt={companyName} class="logo-img" width="300" height="72" />
        </a>
        <button class="nav-toggle" aria-label="Open menu">
          <span></span><span></span><span></span>
        </button>
        <nav class="nav">
          {navItems?.map((item, i) => {
            const label = asStr(item.label)
            const href = asStr(item.href)
            const dropdown = item.dropdown
            if (Array.isArray(dropdown) && dropdown.length > 0) {
              const ddId = `nav-dd-${i}`
              return (
                <div class="nav-dropdown" data-nav-dropdown>
                  <button
                    type="button"
                    class="nav-dropdown-toggle"
                    aria-expanded="false"
                    aria-haspopup="true"
                    aria-controls={ddId}
                    id={`${ddId}-btn`}
                  >
                    {label}
                    <span class="nav-dropdown-chevron" aria-hidden="true"></span>
                  </button>
                  <ul class="nav-dropdown-menu" id={ddId} role="menu">
                    {dropdown.map((link) => (
                      <li role="none">
                        <a href={asStr(link.href)} role="menuitem" {...externalLinkAttrs(asStr(link.href))}>
                          {asStr(link.label)}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )
            }
            return (
              <a href={href} {...externalLinkAttrs(href)}>
                {label}
              </a>
            )
          })}
          <a href={telLink} class="btn btn-primary btn-lg">{callLabelNav}</a>
        </nav>
      </div>
    </div>
  </header>
  <div id="header-nav-spacer" class="header-nav-spacer" aria-hidden="true"></div>

  <main>
    <section class="hero hero-split">
      <div class="hero-bg" style={heroBgStyle}></div>
      <div class="container hero-split-inner">
        <div class="hero-copy">
          <div class="hero-eyebrow">{sfq(asStr(hero?.eyebrow))}</div>
          <h1>{sfq(asStr(hero?.headline))}</h1>
          <p class="hero-typed" aria-live="polite">
            <span id="hero-typed-text"></span><span class="hero-caret" aria-hidden="true">|</span>
          </p>
          <p class="hero-lead">{sfq(asStr(hero?.lead))}</p>
          <div class="hero-actions">
            <a href={telLink} class="btn btn-primary btn-lg cta1-primary-call">{callLabelHero}</a>
          </div>
        </div>
        <form
          class="hero-form"
          data-lead-form="hero"
          action={universalFormAction}
          method={universalFormMethod}
          aria-label={universalFormAriaLabel}
        >
          <div class="hero-form-heading">
            <div class="hero-form-kicker">{universalFormKicker}</div>
            <h2>{universalFormHeadingDisplay}</h2>
          </div>
          <p class="hero-form-sub">{universalFormIntroDisplay}</p>
          <div class="hero-form-grid">
            <div class="hero-form-field">
              <label for="hero-name">
                {asStr(universalFormFields?.nameLabel)}{' '}
                <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
              </label>
              <input id="hero-name" name="name" type="text" required autocomplete="name" />
            </div>
            <div class="hero-form-field">
              <label for="hero-email">
                {asStr(universalFormFields?.emailLabel)}{' '}
                <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
              </label>
              <input id="hero-email" name="email" type="email" required autocomplete="email" />
            </div>
            <div class="hero-form-field">
              <label for="hero-phone">
                {asStr(universalFormFields?.phoneLabel)}{' '}
                <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
              </label>
              <input
                id="hero-phone"
                name="phone"
                type="tel"
                required
                autocomplete="tel"
                maxlength="12"
                inputmode="numeric"
                pattern="[0-9]{3}-[0-9]{3}-[0-9]{4}"
                title="10-digit phone, e.g. 303-762-9841"
              />
            </div>
            <div class="hero-form-field">
              <label for="hero-location">{asStr(universalFormFields?.cityLabel)}</label>
              <input id="hero-location" name="location" type="text" autocomplete="address-level2" />
            </div>
            <div class="hero-form-field hero-form-field-full">
              <label for="hero-message">
                {asStr(universalFormFields?.projectDetailsLabel)}
              </label>
              <textarea id="hero-message" name="message" rows="3"></textarea>
            </div>
          </div>
          <div class="lead-form-honeypot-wrap" aria-hidden="true">
            <label for="hero-website">Leave blank</label>
            <input type="text" id="hero-website" name="website" tabindex="-1" autocomplete="off" />
          </div>
          <p class="lead-form-status" data-lead-form-status role="status" aria-live="polite"></p>
          <button type="submit" class="btn btn-primary btn-lg">{universalSubmitLabel}</button>
        </form>
      </div>
      <section class="brands-marquee" aria-label={sfq(asStr(brandsMarquee?.ariaLabel))}>
        <div class="brands-track">
          <div class="brands-inner">
            {[0, 1, 2].map((idx) => (
              <div class="brands-group" aria-hidden={idx > 0 ? 'true' : undefined}>
                {asStrArray(brandsMarquee?.brands).map((b) => (
                  <span class="brand-pill">{sfq(b)}</span>
                ))}
              </div>
            ))}
          </div>
        </div>
      </section>
    </section>

    <section id="process" class="image-scroller" aria-label={sfq(asStr(projects?.sectionAriaLabel))}>
      <div class="container projects-head">
        <h2 class="section-title">{sfq(asStr(projects?.headline))}</h2>
      </div>
      <div class="projects-carousel" id="projects-carousel">
        {projects?.slides?.map((slide) => {
          const loc = asStr(slide.location)
          const label = `${sfq(asStr(slide.imageAlt))} — ${loc}`
          return (
            <article class="project-slide" data-location={loc} aria-label={label}>
              <img
                src={mediaUrl(asStr(slide.imageSrc))}
                alt={sfq(asStr(slide.imageAlt))}
                width="1200"
                height="800"
                loading="lazy"
                decoding="async"
              />
              <div class="project-meta">
                <span class="project-pin" aria-hidden="true">📍</span>{' '}
                <span class="project-location-label">{loc}</span>
              </div>
            </article>
          )
        })}
      </div>
      <div class="projects-controls projects-controls-bottom" aria-label={sfq(asStr(projects?.controlsAriaLabel))}>
        <button type="button" class="project-nav" id="projects-prev" aria-label={sfq(asStr(projects?.prevAriaLabel))}>
          {sfq(asStr(projects?.prevLabel))}
        </button>
        <button type="button" class="project-nav" id="projects-next" aria-label={sfq(asStr(projects?.nextAriaLabel))}>
          {sfq(asStr(projects?.nextLabel))}
        </button>
      </div>
    </section>

    <section id="why-us" class="section why-simple">
      <div class="container why-choose-layout">
        <div class="why-choose-image-wrap">
          <img
            src={mediaUrl(asStr(whyChoose?.imageSrc))}
            alt={sfq(asStr(whyChoose?.imageAlt))}
            class="why-choose-image"
            width="1200"
            height="800"
            loading="lazy"
            decoding="async"
          />
          <div class="why-choose-stamp">
            <strong>{homesCountDisplay}</strong>
            <span>{sfq(asStr(whyStamp?.line2))}</span>
            <span>{sfq(asStr(whyStamp?.line3))}</span>
          </div>
        </div>
        <div class="why-choose-content">
          <div class="why-eyebrow">{sfq(asStr(whyChoose?.eyebrow))}</div>
          <h2 class="section-title section-title-secondary">{sfq(asStr(whyChoose?.headline))}</h2>
          <p class="section-lead">{sfq(asStr(whyChoose?.lead))}</p>
          <ul class="why-choose-list">
            {whyChoose?.bullets?.map((b) => (
              <li>
                <strong>{sfq(asStr(b.title))}</strong> {sfq(asStr(b.text))}
              </li>
            ))}
          </ul>
          <p class="why-choose-note">{sfq(asStr(whyChoose?.note))}</p>
          <div class="why-choose-actions">
            <a href={telLink} class="btn btn-primary btn-lg">{whyCallLabel}</a>
            <a
              href={asStr(whyCtas?.estimateHref)}
              class="btn btn-outline btn-lg request-estimate"
              {...externalLinkAttrs(asStr(whyCtas?.estimateHref))}
            >
              {sfq(asStr(whyCtas?.estimate))}
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="services" class="section services" style={servicesBgStyle}>
      <div class="container">
        <h2 class="section-title">{servicesHeadlineDisplay}</h2>
        <div class="services-grid">
          {servicesItemsFiltered.map((svc) => (
            <article class="service-card">
              <a href={serviceHref(svc)} class="service-image-wrap" style="display:block; color:inherit; text-decoration:none;">
                <span class="service-number">{asStr(svc.number)}</span>
                <h3 class="service-title">{sfq(asStr(svc.title))}</h3>
                <p class="service-desc">{sfq(asStr(svc.description))}</p>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section about about-video">
      <div class="container about-grid">
        <div class="about-content">
          <div class="about-eyebrow">{sfq(asStr(about?.eyebrow))}</div>
          <h2 class="section-title">{sfq(asStr(about?.headline))}</h2>
          <p class="about-lead">{sfq(asStr(about?.lead))}</p>
          <ul class="about-list">
            {asStrArray(about?.bullets).map((line) => (
              <li>{sfq(line)}</li>
            ))}
          </ul>
          <div class="about-video-actions">
            <a href={telLink} class="btn btn-primary btn-lg">{aboutCallLabel}</a>
            <a
              href={asStr(about?.ctas?.estimateHref)}
              class="btn btn-outline btn-lg request-estimate"
              {...externalLinkAttrs(asStr(about?.ctas?.estimateHref))}
            >
              {sfq(asStr(about?.ctas?.estimate))}
            </a>
          </div>
        </div>
        <div class="about-visual">
          <div class="media-card media-video about-static-visual">
            <img
              src={mediaUrl(aboutStillSrc)}
              alt={sfq(asStr(about?.headline))}
              width="1200"
              height="675"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="section unique-points" style={uniquePointsBgStyle}>
      <div class="container">
        <div class="why-eyebrow">{sfq(asStr(uniquePoints?.eyebrow))}</div>
        <h2 class="section-title section-title-secondary">{sfq(asStr(uniquePoints?.headline))}</h2>
        <div class="unique-grid">
          {uniquePoints?.items?.map((pt) => (
            <article class="result-item">
              <span class="result-value">
                <span class="result-icon" aria-hidden="true">
                  <UniquePointIcon iconId={asStr(pt.iconId)} />
                </span>
                {sfq(asStr(pt.title))}
              </span>
              <p>{sfq(asStr(pt.description))}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="stats-thin" aria-label={sfq(asStr(statsBar?.ariaLabel))}>
      <div class="container stats-thin-grid">
        {statsBar?.items?.map((row) => (
          <div>
            <strong>{statLookup(statsValues, row.valueKey)}</strong>
            <span>{sfq(asStr(row.label))}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="section contact-banner-split">
      <div class="container contact-banner-grid">
        <div class="contact-banner-copy">
          <h2 class="section-title">{sfq(asStr(contactBanner?.headline))}</h2>
          <p class="section-lead">{sfq(asStr(contactBanner?.paragraph1))}</p>
          <p class="section-lead">{sfq(asStr(contactBanner?.paragraph2))}</p>
          <div class="contact-banner-actions">
            <a href={telLink} class="contact-banner-phone">
              <img
                src={mediaUrl(asStr(contactBanner?.phoneIconSrc))}
                alt=""
                aria-hidden="true"
                width="20"
                height="20"
                loading="lazy"
                decoding="async"
              />
              <span class="contact-banner-phone-number">{phoneDisplay}</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="service-area" class="section service-area">
      <div class="container">
        <div class="why-eyebrow">{sfq(asStr(serviceArea?.eyebrow))}</div>
        <h2 class="section-title">{sfq(asStr(serviceArea?.headline))}</h2>
        <p class="section-lead service-area-intro">{sfq(asStr(serviceArea?.intro))}</p>
        <div class="service-area-grid">
          <div class="map-wrap">
            <iframe
              src={mapEmbedUrl}
              width="600"
              height="400"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={mapIframeTitle}
            ></iframe>
          </div>
          <div class="cities-list">
            <p class="cities-label">{sfq(asStr(serviceArea?.citiesLabel))}</p>
            <nav class="cities-nav" aria-label={sfq(asStr(serviceArea?.citiesNavAriaLabel))}>
              {serviceArea?.cities?.map((c) => (
                <a href={normalizeLocationPageHref(c.href)} {...externalLinkAttrs(normalizeLocationPageHref(c.href))}>
                  {asStr(c.name)}
                </a>
              ))}
            </nav>
          </div>
        </div>
      </div>
    </section>

    <section id="team" class="section our-team">
      <div class="container">
        <h2 class="section-title">{sfq(asStr(team?.headline))}</h2>
        <div class="team-grid">
          {team?.members?.map((m) => {
            const memLoc = asStr(m.location)
            return (
            <article class="team-card">
              <img
                src={mediaUrl(asStr(m.imageSrc))}
                alt={sfq(asStr(m.imageAlt))}
                width="640"
                height="480"
                loading="lazy"
                decoding="async"
              />
              <h3>{asStr(m.name)}</h3>
              {memLoc ? <p class="team-location">{sfq(memLoc)}</p> : null}
              <p>{sfq(asStr(m.bio))}</p>
            </article>
            )
          })}
        </div>
      </div>
    </section>

    <section id="faq" class="section faq-section" aria-labelledby={asStr(faq?.headingId)}>
      <div class="container">
        <div class="faq-panel">
          <h2 class="section-title section-title-secondary" id={asStr(faq?.headingId)}>
            {sfq(asStr(faq?.headline))}
          </h2>
          <div class="faq-list" data-faq-accordion>
            {faq?.items?.map((item, idx) => {
              const n = idx + 1
              const btnId = `faq-btn-${n}`
              const panelId = `faq-panel-${n}`
              return (
                <div class="faq-item">
                  <button
                    type="button"
                    class="faq-summary"
                    id={btnId}
                    aria-expanded="false"
                    aria-controls={panelId}
                  >
                    <span class="faq-question">{sfq(asStr(item.question))}</span>
                    <span class="faq-chevron" aria-hidden="true"></span>
                  </button>
                  <div
                    class="faq-answer-outer"
                    id={panelId}
                    role="region"
                    aria-labelledby={btnId}
                    aria-hidden="true"
                  >
                    <div class="faq-answer" set:html={sanitizeCmsHtml(sfq(asStr(item.answerHtml)))} />
                  </div>
                </div>
              )
            })}
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <section id="contact" class="section contact footer-estimate" aria-labelledby="footer-estimate-heading">
      <div class="container">
        <div class="contact-wrapper">
          <div class="contact-info">
            <h2 class="section-title" id="footer-estimate-heading">{sfq(asStr(footerEstimate?.headline))}</h2>
            <p>{sfq(asStr(footerEstimate?.intro))}</p>
            <FooterContactInfo
              variant="estimate"
              phoneTel={tel}
              phoneDisplay={phoneDisplay}
              email={email}
              address={address}
              addressHref={addressHref}
            />
          </div>
          <form
            class="contact-form"
            data-lead-form="footer"
            action={universalFormAction}
            method={universalFormMethod}
          >
            <div class="contact-form-grid">
              <div class="contact-form-field">
                <label for="contact-name">
                  {asStr(universalFormFields?.nameLabel)}{' '}
                  <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
                </label>
                <input type="text" id="contact-name" name="name" required autocomplete="name" />
              </div>
              <div class="contact-form-field">
                <label for="contact-email">
                  {asStr(universalFormFields?.emailLabel)}{' '}
                  <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
                </label>
                <input type="email" id="contact-email" name="email" required autocomplete="email" />
              </div>
              <div class="contact-form-field">
                <label for="contact-phone">
                  {asStr(universalFormFields?.phoneLabel)}{' '}
                  <span class="required-mark" aria-hidden="true">{universalRequiredIndicator}</span>
                </label>
                <input
                  type="tel"
                  id="contact-phone"
                  name="phone"
                  required
                  autocomplete="tel"
                  maxlength="12"
                  inputmode="numeric"
                  pattern="[0-9]{3}-[0-9]{3}-[0-9]{4}"
                  title="10-digit phone, e.g. 303-762-9841"
                />
              </div>
              <div class="contact-form-field">
                <label for="contact-location">{asStr(universalFormFields?.cityLabel)}</label>
                <input type="text" id="contact-location" name="location" autocomplete="address-level2" />
              </div>
              <div class="contact-form-field contact-form-field-full">
                <label for="contact-message">{asStr(universalFormFields?.projectDetailsLabel)}</label>
                <textarea id="contact-message" name="message" rows="4"></textarea>
              </div>
            </div>
            <div class="lead-form-honeypot-wrap" aria-hidden="true">
              <label for="contact-website">Leave blank</label>
              <input type="text" id="contact-website" name="website" tabindex="-1" autocomplete="off" />
            </div>
            <p class="lead-form-status" data-lead-form-status role="status" aria-live="polite"></p>
            <button type="submit" class="btn btn-primary btn-lg">{universalSubmitLabel}</button>
          </form>
        </div>
      </div>
    </section>
    <div class="container">
      <div class="footer-inner">
        <div class="footer-brand-block footer-col">
          <img src={mediaUrl(logoWhite)} alt={companyName} class="footer-logo" width="380" height="78" loading="lazy" decoding="async" />
          <p class="footer-address">{descriptionShort}</p>
          <div class="footer-social" aria-label={asStr(footerBrand?.socialAriaLabel)}>
            {footerBrand?.socialLinks?.map((s) => (
              <a href={asStr(s.href)} aria-label={asStr(s.ariaLabel)} {...externalLinkAttrs(asStr(s.href))}>
                <FooterSocialIcon platform={asStr(s.platform)} />
              </a>
            ))}
          </div>
        </div>
        {footerColumns?.map((col) => (
          <div class="footer-col">
            <p class="footer-heading">{asStr(col.heading)}</p>
            {col.links?.length ? (
              <nav class="footer-links" aria-label={asStr(col.ariaLabel)}>
                {col.links.map((link) => (
                  <a href={asStr(link.href)} {...externalLinkAttrs(asStr(link.href))}>
                    {asStr(link.label)}
                  </a>
                ))}
              </nav>
            ) : null}
            {isContactFooterColumnHeading(col.heading) ? (
              <FooterContactInfo
                variant="footer-column"
                phoneTel={tel}
                phoneDisplay={phoneDisplay}
                email={email}
                address={address}
                addressHref={addressHref}
              />
            ) : null}
            {col.hoursHeading ? (
              <p class="footer-heading footer-hours-heading">{asStr(col.hoursHeading)}</p>
            ) : null}
            {col.hoursText ? <FooterHoursRow hoursText={col.hoursText} /> : null}
          </div>
        ))}
      </div>
    </div>
  </footer>

  <div class="footer-support">
    <div class="container footer-support-inner">
      <p>
        <a href={copyrightHref} set:html={copyrightInnerHtml} {...externalLinkAttrs(copyrightHref)}></a>
      </p>
      <nav aria-label={asStr(footerSupport?.ariaLabel)}>
        {footerSupport?.links?.map((link) => (
          <a href={asStr(link.href)} {...externalLinkAttrs(asStr(link.href))}>
            {asStr(link.label)}
          </a>
        ))}
      </nav>
    </div>
  </div>
  <script
    type="application/json"
    id="homepage-typed-phrases"
    data-fallback-phrase={sfq(asStr(hero?.typedFallbackPhrase))}
    set:html={JSON.stringify(typedPhrases)}
  />
  <style is:global>
    main h1,
    main h2,
    main h3,
    .footer-heading {
      text-transform: capitalize;
    }
  </style>
</BaseLayout>
